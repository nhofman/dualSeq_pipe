
rule all:
    input:
        expand("preprocessing/{sample}_{read}.fastq.gz", sample=sorted(config['entries'].keys()), read=["R1","R2"])

rule trim_reads:
    """Trim paired-end reads with fastp."""
    input:
        reads_forward=lambda wildcards: config['entries'][wildcards.sample]['main']['forward_reads'],
        reads_reverse=lambda wildcards: config['entries'][wildcards.sample]['main']['reverse_reads']
    output:
        fwd="preprocessing/{sample}_R1.fq.gz",
        rev="preprocessing/{sample}_R2.fq.gz",
        json="preprocessing/fastp/{sample}.fastp.json",
        html="preprocessing/fastp/{sample}.fastp.html"
    priority: 1
    log:
        "preprocessing/fastp/log/{sample}.log"
    group: "fastp"
    conda: "../conda_envs/fastp_env.yaml"
    threads:
        2
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastp -w {threads} --in1 {input.reads_forward} --out1 {output.fwd} --in2 {input.reads_reverse} --out2 {output.rev} -h {output.html} -j {output.json} %%ADDITIONAL_FASTP_OPTIONS%%"
