from os import listdir
from os.path import isfile, splitext


def getFilePath(sample_name, forward):
    if forward:
        path = config['entries'][sample_name]['main']['forward_reads']
    else:
        path = config['entries'][sample_name]['main']['reverse_reads']
    return path

rule all:
    input:
        expand("preprocessing/{sample}_R{B}.fastq.gz", sample=sorted(config['entries'].keys()), B=["1","2"])

rule trim_reads:
    input:
        reads_forward=lambda wildcards: config['entries'][wildcards.sample]['main']['forward_reads'],
        reads_reverse=lambda wildcards: config['entries'][wildcards.sample]['main']['reverse_reads']
        #reads_forward=lambda wildcards: getFilePath(wildcards.sample, True),
        #reads_reverse=lambda wildcards: getFilePath(wildcards.sample, False)
    output:
        fwd="preprocessing/{sample}_R1.fastq.gz",
        rev="preprocessing/{sample}_R2.fastq.gz",
        json="preprocessing/{sample}.fastp.json",
        html="preprocessing/{sample}.fastp.html"
    group:
        "fastp"
    conda: "../conda_envs/fastp_env.yaml"
    threads:
        2
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastp -w {threads} --in1 {input.reads_forward} --out1 {output.fwd} --in2 {input.reads_reverse} --out2 {output.rev} -h {output.html} -j {output.json} %%ADDITIONAL_FASTP_OPTIONS%%"
