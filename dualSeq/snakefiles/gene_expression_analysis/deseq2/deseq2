from os import listdir
from os.path import isfile

def getConditions():
    return set([seqRun['deseq2']['condition'] for seqRun in config['entries'].values()])

def getComparisons():
    comparisons = []
    with(open("%%COMPARISONS_HUMAN%%", 'r')) as input_file:
        for line in input_file:
            line = line.strip().replace("\t", "_vs_")
            comparisons.append(line)
    return(comparisons)

localrules: deseq2__create_conditions_human, #deseq2__functional_analysis

COMPARISONS=getComparisons()

rule all:
    input:
        #"gene_expression_analysis/deseq2/counts.txt",
        "gene_expression_analysis/deseq2/counts_normalized.csv",
        "gene_expression_analysis/deseq2/deseq2.RData"

        
rule create_conditions_human:
    output:
        "gene_expression_analysis/deseq2/conditions.txt"
    priority: 1
    run:
        with(open(output[0], 'w')) as output_file:
            for name in config['entries'].keys():
                output_file.write('{},{}\n'.format(name, config['entries'][name]['deseq2']['condition']))

                         
rule deseq2_human:
    input:
        counttable = "gene_expression_analysis/count_table/counts.txt",
        conditions = "gene_expression_analysis/deseq2/conditions.txt"
    output:
        rdata="gene_expression_analysis/deseq2/deseq2.RData",
        counts_normalized="gene_expression_analysis/deseq2/counts_normalized.csv",
        correlation_heatmap="gene_expression_analysis/deseq2/correlation_heatmap.pdf",
        deseq2_tab=expand("gene_expression_analysis/deseq2/deseq2_comparisons_shrunken/deseq2_results_{comp}.csv", comp=COMPARISONS)
    priority: 1
    group:
        "deseq2"
    params:
        output_folder="gene_expression_analysis/deseq2/"
    log:
        "gene_expression_analysis/deseq2/logs/deseq2.log"
    conda: "../conda_envs/R_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "R --vanilla --file=lib/deseq2_analysis.R --args --threads {threads} --counttable {input.counttable} --conditions {input.conditions} --comparisons %%COMPARISONS_HUMAN%% --output {params.output_folder} --color %%COLOR%% --rRNA %%RRNA%% 2>&1 | tee {log}"
  

