
rule all:
	input:
		expand("variant_analyses/variant_calling/{sample}.vcf", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
    #expand("variant_analyses/variant_calling/{virus}_SNP.svg", virus=list(set([entry.split('_')[0] for entry in config['entries'].keys() if "Mock" not in entry])))

rule call_variant:
    input:
        bam="variant_analyses/preprocessing/{sample}_indel.bam",
        bai="variant_analyses/preprocessing/{sample}_indel.bam.bai",
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
    output:
        "variant_analyses/variant_calling/{sample}.vcf"
    priority: 1
    log:
        "variant_analyses/variant_calling/log/{sample}.log"
    group: "lofreq"
    conda: "../conda_envs/variant_env.yaml"
    threads: 3
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "lofreq call-parallel %%ADDITIONAL_LOFREQ_OPTIONS%% --pp-threads {threads} -f {input.genome} -o {output} {input.bam} 2>&1 | tee {log}"



		 
