rule all:
  input:
    expand("variant_analyses/preprocessing/{sample}_indel.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
    expand("variant_analyses/preprocessing/{sample}_realign.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
    expand("variant_analyses/preprocessing/{sample}_dedup.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry]))

rule remove_spliced:
  input:
    "mapping/combined/virus/{sample}.bam"
  output:
    "variant_analyses/preprocessing/{sample}_noSplice.bam"
  priority: 1
  conda: "../conda_envs/samtools_env.yaml"
  resources:
        mem_mb=%%MEM_MB%%
  shell:
    """
    samtools view -h {input} | awk '!($6 ~ /N/)' > {output}.sam
    samtools sort -O bam -o {output} {output}.sam
    #samtools view -h -b {output}.sam > {output}
    rm {output}.sam
    """

rule markDuplicates:
    input:
        "mapping/combined/virus/{sample}_noSplice.bam"
    output:
        bam="variant_analyses/preprocessing/{sample}_dedup.bam",
        metric="variant_analyses/preprocessing/Duplicate_Metric/{sample}"
    priority: 1
    log:
        "variant_analyses/preprocessing/log/{sample}.markDuplicates.log"
    group: "dedup"
    conda: "../conda_envs/variant_env.yaml"
    threads: 1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "picard MarkDuplicates -I {input} -M {output.metric} -O {output.bam} 2>&1 | tee {log}"

# (Probabilistic) realignment
# correct for mapping errors
rule realign:
    input:
        bam="variant_analyses/preprocessing/{sample}_dedup.bam",
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
    output:
        "variant_analyses/preprocessing/{sample}_realign.bam"
    priority: 1
    log:
        "variant_analyses/preprocessing/log/{sample}.realign.log"
    group: "realign"
    conda: "../conda_envs/variant_env.yaml"
    threads: 1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "lofreq viterbi -f {input.genome} {input.bam} | samtools sort -o {output} 2>&1 | tee {log}"
		
# Insert indel qualities
rule indel_qual:
    input:
        bam="variant_analyses/preprocessing/{sample}_realign.bam",
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
    output:
        "variant_analyses/preprocessing/{sample}_indel.bam"
    priority: 1
    log:
        "variant_analyses/preprocessing/log/{sample}.indelQual.log"
    group: "indel_qual"
    conda: "../conda_envs/variant_env.yaml"
    threads: 1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        """
        lofreq indelqual --dindel -f {input.genome} -o {output} {input.bam} 2>&1 | tee {log}
        """

rule index:
    input:
        "variant_analyses/preprocessing/{sample}_indel.bam"
    output:
        "variant_analyses/preprocessing/{sample}_indel.bam.bai"
    priority: 1
    group: "indel_qual"
    conda: "../conda_envs/samtools_env.yaml"
    threads: 1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        """
        samtools index {input}
        """
			 
