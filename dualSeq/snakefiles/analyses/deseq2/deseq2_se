from os import listdir
from os.path import isfile

def getConditions():
    return set([seqRun['deseq2']['condition'] for seqRun in config['entries'].values()])

localrules: deseq2__create_conditions_human, deseq2__functional_analysis


rule all:
    input:
        #"analyses/host/deseq2/counts.txt",
        "analyses/host/deseq2/counts_normalized.csv",
        "analyses/host/deseq2/deseq2.RData",
        "analyses/host/deseq2/GSEA",
        #"analyses/host/deseq2/STRING/"

        
rule create_conditions_human:
    output:
        temp("analyses/host/deseq2/conditions.txt")
    priority: 1
    run:
        with(open(output[0], 'w')) as output_file:
            for name in config['entries'].keys():
                output_file.write('{},{}\n'.format(name, config['entries'][name]['deseq2']['condition']))

                         
rule deseq2_human:
    input:
        counttable = "analyses/host/count_table/counts.txt",
        conditions = "analyses/host/deseq2/conditions.txt",
    output:
        rdata="analyses/host/deseq2/deseq2.RData",
        counts_normalized="analyses/host/deseq2/counts_normalized.csv",
        correlation_heatmap="analyses/host/deseq2/correlation_heatmap.pdf",
    priority: 1
    group:
        "deseq2"
    params:
        output_folder="analyses/host/deseq2/"
    log:
        "analyses/host/deseq2/logs/deseq2.log"
    conda: "../conda_envs/R_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "R --vanilla --file=lib/deseq2_analysis.R --args --threads {threads} --counttable {input.counttable} --conditions {input.conditions} --comparisons %%COMPARISONS_HUMAN%% --output {params.output_folder} "
        "--color %%COLOR%% --rRNA %%RRNA%% 2>&1 | tee {log}"
  
rule functional_analysis:
    localrule: True
    input:
        rdata="analyses/host/deseq2/deseq2.RData"
    output:
        directory("analyses/host/deseq2/GSEA"),
        #directory("analyses/host/deseq2/STRING")
    priority: 1
    group:
        "gsea"
    params:
        output_folder="analyses/host/deseq2/"
    log:
        "analyses/host/deseq2/logs/functional_analysis.log"
    conda: "../conda_envs/R_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "R --vanilla --file=lib/functional_analysis.R --args --threads {threads} --rdata {input.rdata} --db %%DB%% --ont %%ONT%% 2>&1 | tee {log}"

