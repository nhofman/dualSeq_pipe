from os import listdir
from os.path import isfile


rule all:
    input:
        "analyses/host/count_table/counts.txt",
        "analyses/host/count_table/counts.txt.summary",
        multiext("analyses/host/deseq2/counts_assignment_relative", ".pdf", ".png"),
        multiext("analyses/host/deseq2/counts_assignment_absolute", ".pdf", ".png")
        
rule count_reads_host:
    input:
        expand("mapping/combined/host/{host}.bam", host=config['entries'].keys())
    output:
        counts = "analyses/host/count_table/counts.txt",
        summary = "analyses/host/count_table/counts.txt.summary"
    priority: 1
    log:
        "analyses/host/count_table/logs/featurecounts.log"
    group:
        "count_reads_host"
    conda: "../conda_envs/counts_env.yaml"
    threads:
        8
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "featureCounts -T {threads} %%ADDITIONAL_FEATCOUNTS_OPTIONS%% -t '%%GFF_FEATURE_TYPE_HUMAN%%' -g '%%GFF_FEATURE_NAME_HUMAN%%' -a %%GFF_HUMAN%% -o {output.counts} {input} 2>&1 | tee {log}"

            
rule plot_assignment:
    input:
        feature_counts_log = "analyses/host/count_table/counts.txt.summary"
    output:
        multiext("analyses/host/deseq2/counts_assignment_relative", ".pdf", ".png"),
        multiext("analyses/host/deseq2/counts_assignment_absolute", ".pdf", ".png")
    priority: 1
    log:
        "analyses/host/count_table/logs/plot_featurecounts.log"
    group:
        ""
    conda: "../conda_envs/R.yaml"
    shell:
        "R --vanilla --file=lib/plot_assignment.R --args --featurecounts_log {input} 2>&1 | tee {log}"