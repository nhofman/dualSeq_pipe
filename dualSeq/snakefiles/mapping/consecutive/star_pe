
rule all:
    input:
        expand("mapping/{sample}.bam", sample=config['entries'].keys()),
        expand("mapping/{sample}.bam.bai", sample=config['entries'].keys())

rule star_index:
    input:
        genome_host="%%HOST_GENOME%%"
    output:
        "mapping/star_index/SA"
    params:
        "mapping/star_index/"
    priority: 1
    log:
        "mapping/logs/star_index.log"
    group:
        "star_index"
    conda: "../conda_envs/star_env.yaml"
    threads:
        4
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        """
	STAR --runThreadN {threads} --runMode genomeGenerate --genomeDir {params} --genomeFastaFiles {input.genome_host} --sjdbGTFfile %%HOST_GTF%% --sjdbOverhang %%STAR_SJ_OVERHANG%% --sjdbGTFfeatureExon %%STAR_FEATURE_EXON%% --sjdbGTFtagExonParentGene %%STAR_GENE_TAG%% --sjdbGTFtagExonParentTranscript %%STAR_TRANSCRIPT_TAG%% 2>&1 | tee {log}
	    
	"""


rule star_mapping:
    input:
        index_dir="mapping/star_index/SA",
        reads_fwd="preprocessing/{sample}_R1.fastq.gz",
        reads_rev="preprocessing/{sample}_R2.fastq.gz"
        #index_dir=lambda wildcards: os.path.splitext(config['entries'][wildcards.sample]['combined']['virus_genome'])[0]
        #reads=lambda wildcards: os.path.join('preprocessing', os.path.basename(config['entries'][wildcards.sample]['main']['reads']))
    output:
        bam="mapping/{sample}.bam",
        summary="mapping/{sample}Log.final.out",
        fasta="mapping/{sample}Unmapped.out.mate1"
    params:
        prefix="mapping/{sample}",
        index="mapping/star_index"
    priority: 1
    log:
        "mapping/logs/star_mapping.{sample}.log"
    group:
        "star_mapping"
    conda: "../conda_envs/star_env.yaml"
    threads:
        2
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        "STAR --runThreadN {threads} --runMode alignReads --genomeDir {params.index} --readFilesIn {input.reads_fwd} {input.reads_rev} --outSAMtype BAM SortedByCoordinate --outFileNamePrefix {params.prefix} --outReadsUnmapped Fastx %%ADDITIONAL_STAR_OPTIONS%% 2>&1 |"
        " tee {log}; mv {params.prefix}Aligned.sortedByCoord.out.bam {params.prefix}.bam"


rule bam_idx:
    input:
        "mapping/{sample}.bam"
    output:
        "mapping/{sample}.bam.bai"
    conda: "../conda_envs/samtools_env.yaml"
    group:
        "star_mapping"
    shell:
        """
        samtools index {input}
        """
