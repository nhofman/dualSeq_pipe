from os import listdir
from os.path import isfile, splitext, isdir

MOCK_SAMPLES = [entry for entry in config['entries'].keys() if 'virus_genome' not in config['entries'][entry]['main'].keys()]
INFECTED_SAMPLES = [entry for entry in config['entries'].keys() if 'virus_genome' in config['entries'][entry]['main'].keys()]

rule all:
    input:
        expand("mapping/host/{sample}.bam", sample=MOCK_SAMPLES + INFECTED_SAMPLES),
        expand("mapping/virus/{sample}.bam", sample=INFECTED_SAMPLES),
        #expand("mapping/virus/stats/{sample}_stats.csv", sample=INFECTED_SAMPLES),
        #expand("mapping/host/stats/{sample}_stats.csv", sample=MOCK_SAMPLES + INFECTED_SAMPLES),
        multiext("mapping/stats/mapping_statistic", ".csv", ".xlsx"),
        multiext("mapping/stats/mapping_statistic", ".pdf", ".png")
    
    
rule mapping_stats_tsv:
    input:
        expand("mapping/host/{sample}Log.final.out", sample=config['entries'].keys())
    output:
        "mapping/host/stats/mapping_stats.tsv"
    run:
        
        with open(output[0], 'w') as summary_file:
            summary_file.write("sample	total_reads	avg_input_read_length	uniquely_mapped	uniquely_mapped_percent	avg_mapped_read_length	num_splices	num_annotated_splices	num_GT/AG_splices	num_GC/AG_splices	num_AT/AC_splices	num_noncanonical_splices	mismatch_rate	deletion_rate	deletion_length	insertion_rate	insertion_length	multimapped	multimapped_percent	multimapped_toomany	multimapped_toomany_percent	unmapped_mismatches_percent	unmapped_tooshort_percent	unmapped_other_percent	chimeric	chimeric_percent\n")
            #pattern = {}
            for i in input:
                summary_file.write(i.replace("Log.final.out", "").replace("mapping/host/", "") + "	")
                #with open(i, "r") as input_file:
                for line in shell("tail -n +5 {i}", iterable=True):
                        if "|" in line:
                            line_data = line.split("|")
                            summary_file.write(line_data[1].split()[0] + "	")
                summary_file.write("\n")
        

rule star_index:
    """Create STAR index for host reference"""
    input:
        genome="%%HOST_GENOME%%"
        #index_dir="%%STAR_INDEX_DIR%%"
    output:
        directory("%%STAR_INDEX_DIR%%")
        #"%%STAR_INDEX_DIR%%"+"SAindex"
    priority: 1
    log:
        "mapping/logs/star_index.log"
    group:
        "star_index"
    conda: "../conda_envs/star_env.yaml"
    threads:
        %%THREADS_IDX_HOST%%
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        "STAR --runThreadN {threads} --runMode genomeGenerate --genomeDir %%STAR_INDEX_DIR%% --genomeFastaFiles {input.genome} --sjdbGTFfile %%HOST_GTF%% --sjdbOverhang %%STAR_SJ_OVERHANG%% --sjdbGTFfeatureExon %%STAR_FEATURE_EXON%% --sjdbGTFtagExonParentGene %%STAR_GENE_TAG%% --sjdbGTFtagExonParentTranscript %%STAR_TRANSCRIPT_TAG%% --outTmpDir {params.tmp} 2>&1 |"
        "tee {log}"


rule star_mapping:
    """Map preprocessed reads to the indexed reference genome."""
    input:
        index_dir="%%STAR_INDEX_DIR%%",
        reads1="preprocessing/{sample}_R1.fq.gz",
        reads2="preprocessing/{sample}_R2.fq.gz"
    output:
        bam="mapping/host/{sample}.bam",
        summary="mapping/host/{sample}Log.final.out",
        unmap1="mapping/host/{sample}Unmapped.out.mate1",
        unmap2="mapping/host/{sample}Unmapped.out.mate2"
    params:
        prefix="mapping/host/{sample}"
    priority: 1
    log:
        "mapping/logs/star_mapping.{sample}.log"
    group:
        "star_mapping"
    conda: "../conda_envs/star_env.yaml"
    threads:
        %%THREADS_MAPPING_HOST%%
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        "STAR --runThreadN {threads} --runMode alignReads --genomeDir {input.index_dir} --readFilesIn {input.reads1} {input.reads2} --outSAMtype BAM SortedByCoordinate --outFileNamePrefix {params.prefix} --outReadsUnmapped Fastx %%ADDITIONAL_STAR_OPTIONS%% 2>&1 |"
        " tee {log}; mv {params.prefix}Aligned.sortedByCoord.out.bam {params.prefix}.bam"        

rule unmapped_to_fastq:
    input:
        unmap1="mapping/host/{sample}Unmapped.out.mate1",
        unmap2="mapping/host/{sample}Unmapped.out.mate2"
    output:
        unmap1="mapping/host/unmapped/{sample}_R1.fastq",
        unmap2="mapping/host/unmapped/{sample}_R2.fastq"
    shell:
        "mv {input.unmap1} {output.unmap1}"
        "mv {input.unmap2} {output.unmap2}"

rule bowtie2_index:
    """Create index for pathogen genomes listed in sample file."""
    input:
        "{genome_name}"
    output:
        "{genome_name}.1.bt2"
    priority: 1
    group:
        "bowtie2_index"
    log:
        "mapping/virus/logs/bowtie2_index_{genome_name}.log"
    conda: "../conda_envs/bowtie2_env.yaml"
    threads:
        %%THREADS_IDX_VIRUS%%
    resources:
        mem_mb=%%MEM_MB_BOWTIE2%%
    shell:
        "bowtie2-build --threads {threads} {input} {input} 2>&1 |"
        "tee {log}"

rule bowtie2_mapping:
    """Map reads that could not be mapped against the host reference to the pathogen (virus) genome."""
    input:
        genome_index=lambda wildcards: config['entries'][wildcards.sample]['main']['virus_genome'] + ".1.bt2",
        reads1="mapping/host/unmapped/{sample}_R1.fastq",
        reads2="mapping/host/unmapped/{sample}_R2.fastq"
    output:
        sam="mapping/virus/{sample}.sam",
        unmapped="mapping/virus/unmapped/{sample}_unmapped.fastq"
    params:
        prefix=lambda wildcards: config['entries'][wildcards.sample]['main']['virus_genome']
    priority: 1
    group:
        "bowtie2_mapping"
    log:
        "mapping/virus/logs/bowtie2_mapping.{sample}.log"
    conda: "../conda_envs/bowtie2_env.yaml"
    threads:
        %%THREADS_MAPPING_VIRUS%%
    resources:
        mem_mb=%%MEM_MB_BOWTIE2%%
    shell:
        "bowtie2 %%ADDITIONAL_BOWTIE2_OPTIONS%% -p {threads} --mm %%ALIGNMENT_TYPE_VIRUS%% -x {params.prefix} -1 {input.reads1} -2 {input.reads2} -S {output.sam} --un {output.unmapped} 2>&1 |"
        "tee {log}"

rule sam_to_bam:
    input:
        "mapping/virus/{sample}.sam"
    output:
        bam="mapping/virus/{sample}.bam",
        bai="mapping/virus/{sample}.bam.bai",
        bam_unmapped="mapping/virus/unmapped/{sample}_unmap.bam"
    group:
        "bowtie2_mapping"
    conda: "../conda_envs/samtools_env.yaml"
    threads:
        2
    shell:
        "samtools view -F 4 -Shb {input} | samtools sort -@ {threads} -o {output.bam} - && samtools index {output.bam};"
        "samtools view -f 4 -Shb {input} | samtools sort -@ {threads} -o {output.bam_unmapped} -"

rule star_stat:
    """Generate mapping statistic for host files."""
    input:
        host_bam="mapping/host/{sample}.bam",
    output:
        "mapping/host/stats/{sample}_stats.csv"
    priority: 1
    group:
        "bam_process"
    conda: "../conda_envs/samtools_env.yaml"
    shell:
        """
        mapped_host=$(samtools view -c -F 3340 {input.host_bam})
        proper_pairs=`awk "BEGIN {{print ${{mapped_host}}/2}}"`
        uniquely_host=$(samtools view -c -F 3340 -f 2 -q 255 {input.host_bam})
        proper_pairs_uniq=`awk "BEGIN {{print ${{uniquely_host}}/2}}"`
        total=`awk '{{if($0 ~ "Number of input reads"){{ split($0, x, "|"); gsub("\t","",x[2]); print x[2]}}}}' mapping/{wildcards.sample}Log.final.out`
	echo $'sample,total_reads,mapped,uniquely_mapped,group' > {output}
        echo {wildcards.sample}','${{total}}','${{proper_pairs}}','${{proper_pairs_uniq}}',host' >> {output}
        """

rule bowtie2_stat:
    input:
        log="mapping/virus/logs/bowtie2_mapping.{sample}.log",
        bam="mapping/virus/{sample}.bam"
    output:
        "mapping/virus/stats/{sample}_stats.csv"
    priority: 1
    group:
        "bam_process"
    conda: "../conda_envs/samtools_env.yaml"
    shell:
        """
        mapped_virus=$(samtools view -c -F 3340 {input.bam})
        uniquely_virus=$(grep "aligned concordantly exactly 1 time" "{input.log}" | awk '{{print $1}}')
        #mapped_multi=$(grep "aligned concordantly >1 times" "{input.log}" | awk '{{print $1}}')
        total=$(grep "reads" "{input.log}" | awk '{{print $1}}')
        echo $'sample,total_reads,mapped,uniquely_mapped,group' > {output}
        echo {wildcards.sample}','${{total}}','${{mapped_virus}}','${{uniquely_virus}}',virus' >> {output}
        """

rule plot_statistics:
    """Plot mapping statistic."""
    input:
        stat_host=expand("mapping/host/stats/{sample}_stats.csv", sample=INFECTED_SAMPLES+MOCK_SAMPLES),
        stat_virus=expand("mapping/virus/stats/{sample}_stats.csv", sample=INFECTED_SAMPLES)
    output:
        multiext("mapping/stats/mapping_statistic", ".csv", ".xlsx"),
        multiext("mapping/stats/mapping_statistic", ".pdf", ".png")
    params:
        "mapping/"
    priority: 1
    conda: "../conda_envs/R_env.yaml"
    shell:
        """
        R --vanilla --file=lib/plot_mapping_stats_pe.R --args --stat-host mapping/host/stats/ --stat-virus mapping/virus/stats/ --output {params}
        """
