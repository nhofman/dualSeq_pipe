        both_virus=$(samtools view -F 3340 -N {input.both} {input.virus_bam} | wc -l) || true
        echo $'sample,total_reads,mapped,uniquely_mapped,mapped_to_both,group' > {output}
        echo {wildcards.sample}','${{total}}','${{proper_pairs}}','${{proper_pairs_uniq}}','${{both_virus}}',virus' >> {output}
        """

rule plot_statistics:
    input:
        stat_host=expand("mapping/host/stats/{sample}_stats.csv", sample=config['entries'].keys()),
        stat_virus=expand("mapping/virus/stats/{sample}_stats.csv", sample=INFECTED_SAMPLES)
    output:
        multiext("mapping/stats/mapping_statistic", ".csv", ".xlsx"),
        multiext("mapping/stats/mapping_statistic", ".pdf", ".png"),
        multiext("mapping/stats/mapping_statistic_mock", ".pdf", ".png")
    params:
        "mapping/"
    priority: 1
    conda: "../conda_envs/R_env.yaml"
    shell:
        """
        R --vanilla --file=lib/plot_mapping_stats_pe.R --args --stat-host mapping/host/stats/ --stat-virus mapping/virus/stats/ --output {params}
        """
