        mapped_virus=$(samtools view -c -F 3340 {input.virus_bam})
        proper_pairs=`awk "BEGIN {{print ${{mapped_virus}}/2}}"`
        uniquely_virus=$(samtools view -c -F 3340 -f 2 -q 255 {input.virus_bam})
