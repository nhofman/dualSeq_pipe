from os import listdir
from os.path import isfile, basename, splitext

rule all:
    input:
        "report/multiqc/multiqc_report.html"

rule parse_envs:
    input:
        "conda_envs"
    output:
        "report/multiqc/multiqc_config.yaml"
    log:
        "report/multiqc/log/parse_envs.log"
    shell:
        """
        python scripts/parse_software_versions.py {input} {output} 2>&1 | tee {log}
        """

rule multiqc:
    input:
        rules.multiqc__parse_envs.output,
        expand("QC/fastqc/{A}_R{B}_fastqc.html", A=config['entries'].keys(), B=["1","2"]),
        expand("preprocessing/{sample}_R{B}.fastq.gz", sample=config['entries'].keys(), B=["1","2"])
    output:
        "report/multiqc/multiqc_report.html"
    params:
        "QC/fastqc",
        "preprocessing/"
    log:
        "report/multiqc/log/multiqc.log"
    group:
        "multiqc"
    conda: "../conda_envs/multiqc_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "multiqc %%ADDITIONAL_MULTIQC_OPTIONS%% --force --ignore .snakemake --config {input[0]} --outdir report/multiqc . 2>&1 | tee {log}"

