
rule all:
	input:
		expand("variant_analysis/variant_analysis/{sample}.vcf", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
        #expand("variant_analysis/variant_analysis/{virus}_SNP.svg", virus=list(set([entry.split('_')[0] for entry in config['entries'].keys() if "Mock" not in entry]))),
        "variant_analysis/variant_analysis/plots/Count_SNP.pdf",
        "variant_analysis/variant_analysis/plots/Frequency_density.pdf"

rule call_variant:
    input:
        bam="variant_analysis/preprocessing/{sample}_indel.bam",
        bai="variant_analysis/preprocessing/{sample}_indel.bam.bai",
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
    output:
        "variant_analysis/variant_analysis/{sample}.vcf"
    priority: 1
    log:
        "variant_analysis/variant_analysis/log/{sample}.log"
    group: "lofreq"
    conda: "../conda_envs/variant_env.yaml"
    threads: 3
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "lofreq call-parallel %%ADDITIONAL_LOFREQ_OPTIONS%% --pp-threads {threads} -f {input.genome} -o {output} {input.bam} 2>&1 | tee {log}"

rule sample2gff:
    output:
        "variant_analysis/variant_analysis/sample2gff.txt"
    priority: 1
    run:
        with(open(output[0], 'w')) as output_file:
            for name in config['entries'].keys():
                output_file.write('{},{}\n'.format(name, config['entries'][name]['combined']['virus_genome_annotation']))

rule plot_snp:
    input:
        gff="variant_analysis/variant_analysis/sample2gff.txt",
        vcf="variant_analysis/variant_analysis"
    output:
        "variant_analysis/variant_analysis/plots/Count_SNP.pdf",
        "variant_analysis/variant_analysis/plots/Frequency_density.pdf"
    params:
        output_folder="variant_analysis/variant_analysis/plots"
    priority: 1
    shell:
        "R --vanilla --file=lib/compare_SNP.R --args --vcf {input.vcf} --gff {input.gff} --output {params.output_folder}"
