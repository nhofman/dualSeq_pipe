rule deseq2__create_conditions_human:
    output:
        temp("analyses/host/deseq2/conditions.txt")
    priority: 1
    run:
        with(open(output[0], 'w')) as output_file:
            for name in sorted(config['entries'].keys()):
                output_file.write('{}\t{}\n'.format(name, config['entries'][name]['deseq2']['condition']))

                         
rule deseq2__deseq2_human:
    input:
        counttable = "analyses/host/count_table/counts.txt",
        conditions = "analyses/host/deseq2/conditions.txt",
        feature_counts_log = "analyses/host/count_table/counts.txt.summary"
    output:
        rdata="analyses/host/deseq2/deseq2.RData",
        counts_normalized="analyses/host/deseq2/counts_normalized.tsv",
        correlation_heatmap="analyses/host/deseq2/correlation_heatmap.pdf",
        assignment_statistics="analyses/host/deseq2/counts_assignment.pdf",
        #summary=expand('analyses/host/deseq2/summary/{COND}.tsv', COND=getConditions())
        #comparisons=directory("analyses/host/deseq2/deseq2_comparisons")
    priority: 1
    group:
        "deseq2"
    params:
        output_folder="analyses/host/deseq2/"
    log:
        "analyses/host/deseq2/logs/deseq2.log"
    conda: "../conda_envs/R_env.yaml"
    threads:
        1
    resources:
        mem_mb=2000
    shell:
        "R --vanilla --file=snakemake_lib/deseq2_lib/deseq2_analysis.R --args --threads {threads} --counttable {input.counttable} --conditions {input.conditions} --comparisons /home/nina/Documents/Virus_project/dualSeq_pipeline/comparisons_new.txt --output {params.output_folder} "
        "--featcounts-log {input.feature_counts_log} --color NULL --rRNA /vol/sfb1021/SFB1021_Virus/genomes/hg38/rRNA_genes.txt 2>&1 | tee {log}"

  
rule deseq2__functional_analysis:
    input:
        rdata="analyses/host/deseq2/deseq2.RData"
    output:
        directory("analyses/host/deseq2/GSEA"),
        #directory("analyses/host/deseq2/STRING")
    priority: 1
    group:
        "deseq2"
    params:
        output_folder="analyses/host/deseq2/"
    log:
        "analyses/host/deseq2/logs/functional_analysis.log"
    conda: "../conda_envs/R_env.yaml"
    threads:
        1
    shell:
        "R --vanilla --file=snakemake_lib/deseq2_lib/functional_analysis.R --args --threads {threads} --rdata {input.rdata} --db GO,KEGG --ont CC,MF,BP 2>&1 | tee {log}"

