    input:
        #"analyses/host/deseq2/counts.txt",
        "analyses/host/deseq2/counts_normalized.tsv",
        "analyses/host/deseq2/deseq2.RData",
        "analyses/host/deseq2/GSEA",
        #"analyses/host/deseq2/STRING/"

