rule all:
    input:
        expand("preprocessing/fastqc/{A}_fastqc.html", A=sorted(config['entries'].keys()))

rule fastqc:
    input:
        lambda wildcards: config['entries'][wildcards.sample]['main']['reads']
    output:
        "preprocessing/fastqc/{sample}_fastqc.html",
        "preprocessing/fastqc/{sample}_fastqc.zip"
    group:
        "fastqc"
    conda: "conda_envs/fastqc_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastqc %%ADDITIONAL_FASTQC_OPTIONS%% -o preprocessing/fastqc {input}"
