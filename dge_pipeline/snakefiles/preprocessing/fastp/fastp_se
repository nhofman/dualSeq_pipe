from os import listdir
from os.path import isfile, splitext

rule all:
    input:
        expand("preprocessing/{A}.fq.gz", A=sorted(config['entries'].keys()))

rule trim_reads:
    input:
        lambda wildcards: config['entries'][wildcards.sample]['main']['reads']
    output:
        "preprocessing/{sample}.fq.gz",
        "preprocessing/fastp/{sample}_fastp.json"
    group:
        "fastp"
    conda: "conda_envs/fastp_env.yaml"
    threads:
        2
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastp -w {threads} --in1 {input} --out1 {output} -h preprocessing/fastp/{wildcards.sample}_fastp.html -j preprocessing/fastp/{wildcards.sample}_fastp.json %%ADDITIONAL_FASTP_OPTIONS%%"
