def get_virus_vcf(wildcards):
    vcf = list()
    for entry in config['entries'].keys():
        if wildcards.virus in entry:
            vcf.append("variant_analyses/variant_calling/"+entry+".vcf")
            gff = config['entries'][entry]['combined']['virus_genome_annotation']
    vcf.insert(0,gff)
    return vcf

def get_virus_bw(wildcards):
    bw = list()
    for entry in config['entries'].keys():
        if wildcards.virus in entry:
            bw.append("summary/bigwig/virus/"+entry+".bigWig")
    return bw



rule visualize:
        input:
                vcf=get_virus_vcf,
                bw=get_virus_bw
        output:
                "variant_analyses/variant_calling/{virus}_SNP.svg",
                "variant_analyses/variant_calling/{virus}_Coverage.svg"
        run:
                gff=input.vcf[0]
                vcf=','.join(input.vcf[1:])
                shell("R --vanilla --file=lib/plot_snp.R --args --gff {gff} --vcf {vcf}")

		 
