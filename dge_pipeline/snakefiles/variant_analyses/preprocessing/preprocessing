rule all:
  input:
    expand("variant_analyses_combined/preprocessing/{sample}_indel.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
    expand("variant_analyses_combined/preprocessing/{sample}_realign.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
    expand("variant_analyses_combined/preprocessing/{sample}_dedup.bam", sample=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry]))

rule remove_spliced:
  input:
    "mapping/combined/virus/{sample}.bam"
  output:
    "mapping/combined/virus/{sample}_noSplice.bam"
  shell:
    """
    samtools view -h {input} | awk '!($6 ~ /N/)' > {output}.sam
    samtools view -h -b {output}.sam > {output}
    rm {output}.sam
    """

rule markDuplicates:
  input:
    "mapping/combined/virus/{sample}_noSplice.bam"
  output:
    bam="variant_analyses_combined/preprocessing/{sample}_dedup.bam",
    metric="variant_analyses_combined/preprocessing/Duplicate_Metric/{sample}"
  threads: 1
  group: "dedup"
  shell:
    "picard MarkDuplicates -I {input} -M {output.metric} -O {output.bam}"

# (Probabilistic) realignment
# correct for mapping errors
rule realign:
  input:
    bam="variant_analyses_combined/preprocessing/{sample}_dedup.bam",
    genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
  output:
    "variant_analyses_combined/preprocessing/{sample}_realign.bam"
  threads: 1
  group: "realign"
  shell:
    "lofreq viterbi -f {input.genome} {input.bam} | samtools sort - > {output}"
		
# Insert indel qualities
rule indel_qual:
  input:
    bam="variant_analyses_combined/preprocessing/{sample}_realign.bam",
    genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome']
  output:
    "variant_analyses_combined/preprocessing/{sample}_indel.bam"
  threads: 1
  group: "indel_qual"
  shell:
    "lofreq indelqual --dindel -f {input.genome} -o {output} {input.bam}"
		 
