from os import listdir
from os.path import isfile, basename, splitext


rule all:
    input:
        "summary/multiqc/multiqc_report.html"

rule parse_envs:
    input:
        "envs"
    output:
        "multiqc_config.yaml"
    shell:
        """
        python scripts/parse_software_versions.py {input}
        """

rule multiqc:
    input:
        #expand("summary/multiqc/fastqc/{A}_fastqc.html", A=sorted(config['entries'].keys())),
        expand("preprocessing/{A}.fastp.json", A=sorted(config['entries'].keys())),
        expand("mapping/combined/{A}Log.final.out", A=sorted(config['entries'].keys())),
        #expand("mapping/virus/logs/bowtie2_mapping.{A}.log", A=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
        #expand("analyses/virus/count_table/{A}counts.txt.summary", A=[splitext(basename(seqRun['main']['reads']))[0] for seqRun in config['entries'].values()])
        "analyses/host/count_table/counts.txt.summary"
    output:
        "summary/multiqc/multiqc_report.html"
    params:
        "preprocessing/",
        #"mapping/combined/virus/logs",
        "mapping/combined/",
        "analyses/host/count_table"
    group:
        "multiqc"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "multiqc %%ADDITIONAL_MULTIQC_OPTIONS%% -o summary/multiqc {params}"
