rule all:
    input:
        expand("QC/fastqc/{A}_fastqc.html", A=sorted(config['entries'].keys()))

rule fastqc:
    input:
        lambda wildcards: config['entries'][wildcards.sample]['main']['reads']
    output:
        "QC/fastqc/{sample}_fastqc.html",
        "QC/fastqc/{sample}_fastqc.zip"
    priority: 1
    log:
        "QC/fastqc/log/{sample}.log"
    group:
        "fastqc"
    conda: "conda_envs/fastqc_env.yaml"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastqc %%ADDITIONAL_FASTQC_OPTIONS%% -o QC/fastqc {input} 2>&1 | tee {log}"
