from os import listdir
from os.path import isfile, basename, splitext

rule all:
    input:
        expand("premapping/fastqc/{A}_fastqc.html", A=sorted(config['entries'].keys())) 

rule fastqc:
    input:
        #"preprocessing/{A}.fq.gz"
        lambda wildcards: config['entries'][wildcards.sample]['main']['reads']
    output:
        "premapping/fastqc/{sample}_fastqc.html",
        "premapping/fastqc/{sample}_fastqc.zip"
    group:
        "fastqc"
    threads:
        1
    resources:
        mem_mb=%%MEM_MB%%
    shell:
        "fastqc -o premapping/fastqc/{wildcards.sample} {input}"
