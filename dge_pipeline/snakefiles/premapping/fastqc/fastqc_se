from os import listdir
from os.path import isfile, basename, splitext

rule all:
    input:
        expand("premapping/fastqc/{A}_fastqc.html", A=sorted(config['entries'].keys())) #A=sorted(config['entries'].keys()))

rule fastqc:
    input:
        "preprocessing/{A}.fq.gz"
    output:
        "premapping/fastqc/{A}_fastqc.html",
        "premapping/fastqc/{A}_fastqc.zip"
    group:
        "fastqc"
    threads:
        1
    shell:
        "fastqc -o premapping/fastqc {input}"
