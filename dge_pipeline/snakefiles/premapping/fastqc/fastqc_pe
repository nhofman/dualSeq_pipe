from os import listdir
from os.path import isfile, basename, splitext

rule all:
    input:
        expand("premapping/fastqc/{A}_{B}_fastqc.html", A=sorted(config['entries'].keys()), B=["R1","R2"])

rule fastqc:
    input:
        "preprocessing/{sample}_R{direction}.fastq"
    output:
        "premapping/fastqc/{sample}_R{direction}_fastqc.html",
        "premapping/fastqc/{sample}_R{direction}_fastqc.zip"
    group:
        "fastqc"
    threads:
        1
    shell:
        "fastqc -o premapping/fastqc {input}"
