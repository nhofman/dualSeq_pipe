def virus2genome(wildcards):
	for sample in config['entries'].keys():
		if 'Mock' in sample:
			if wildcards.virus == "None":
				return("None","None")
		elif wildcards.virus in config['entries'][sample]['combined']['virus_genome']:
			files = [config['entries'][sample]['combined']['virus_genome'], config['entries'][sample]['combined']['virus_genome_annotation']]
			print(files)
			return files

def annotation_name(wildcards):
	filename, file_extension = os.path.splitext("%%HOST_GTF%%")
	anno_file = filename+"_"+wildcards.virus+file_extension
	return anno_file

rule star_index:
    input:
        genome_host="%%HOST_GENOME%%"
    output:
        directory("%%STAR_INDEX_DIR%%".rstrip("/")+"_"+"{virus}")
    params:
        #genome_virus=lambda wildcards: virus2genome(wildcards),
        filelist=virus2genome,
        tmp=temp("%%STAR_INDEX_DIR%%".rstrip("/")+"_"+"{virus}"+"_tmp"),
        ann_file=annotation_name
    group:
        "star_index"
    log:
        "mapping/combined/logs/star_index_"+"{virus}"+".log"
    conda: "conda_envs/star_env.yaml"
    threads:
        4
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        """
        echo {wildcards.virus}
	echo params
        if [[ "{wildcards.virus}" == "None" ]]
	then
		STAR --runThreadN {threads} --runMode genomeGenerate --genomeDir {output} --genomeFastaFiles {input.genome_host} --sjdbGTFfile %%HOST_GTF%% --sjdbOverhang %%STAR_SJ_OVERHANG%% --sjdbGTFtagExonParentTranscript %%STAR_PARENT_TAG%% --outTmpDir {params.tmp} 2>&1 | tee {log}
	else
		echo {params.filelist}
		echo {params.filelist[0]}
		touch {params.ann_file}    
		cat %%HOST_GTF%% > {params.ann_file}
		cat {params.filelist[1]} >> {params.ann_file}
		STAR --runThreadN {threads} --runMode genomeGenerate --genomeDir {output} --genomeFastaFiles {input.genome_host} {params.filelist[0]} --sjdbGTFfile {params.ann_file} --sjdbOverhang %%STAR_SJ_OVERHANG%% --sjdbGTFtagExonParentTranscript %%STAR_PARENT_TAG%% --outTmpDir {params.tmp} 2>&1 | tee {log}
	fi
	"""

def get_genome(wildcards):
	host = "%%STAR_INDEX_DIR%%".rstrip("/")
	if 'Mock' in wildcards.sample:
		return(host+"_None")
	else:
		virus = os.path.splitext(os.path.basename(config['entries'][wildcards.sample]['combined']['virus_genome']))[0]
		return(host+"_"+virus)

rule star_mapping:
    input:
        index_dir=get_genome, #"%%STAR_INDEX_DIR%%",
        reads="preprocessing/{sample}.fq.gz",
        #index_dir=lambda wildcards: os.path.splitext(config['entries'][wildcards.sample]['combined']['virus_genome'])[0]
        #reads=lambda wildcards: os.path.join('preprocessing', os.path.basename(config['entries'][wildcards.sample]['main']['reads']))
    output:
        bam="mapping/combined/{sample}.bam",
        summary="mapping/combined/{sample}Log.final.out",
        fasta="mapping/combined/{sample}Unmapped.out.mate1"
    params:
        prefix="mapping/combined/{sample}"
    group:
        "star_mapping"
    log:
        "mapping/combined/logs/star_mapping.{sample}.log"
    conda: "conda_envs/star_env.yaml"
    threads:
        2
    resources:
        mem_mb=%%MEM_MB_STAR%%
    shell:
        #--outReadsUnmapped Fastx
        "STAR --runThreadN {threads} --runMode alignReads --genomeDir {input.index_dir} --readFilesIn {input.reads} --outSAMtype BAM SortedByCoordinate --outFileNamePrefix {params.prefix} --outReadsUnmapped Fastx %%ADDITIONAL_STAR_OPTIONS%% 2>&1 |"
        " tee {log}; mv {params.prefix}Aligned.sortedByCoord.out.bam {params.prefix}.bam"

rule index_bam:
    input:
        "mapping/combined/{sample}.bam"
    output:
        "mapping/combined/{sample}.bam.bai"
    log:
        "mapping/combined/logs/index.{sample}.log"
    group:
        "star_mapping"
    conda: "conda_envs/star_env.yaml"
    #resources: cpus=1, mem_mb=4000
    shell:
        "samtools index {input} 2>&1 | tee {log}"

rule Mock:
    input:
        bam = "mapping/combined/{sample}.bam",
        bai = "mapping/combined/{sample}.bam.bai"
    output:
        bam = "mapping/combined/host/{sample}.bam",
        stat = "mapping/combined/host/stats/{sample}_stats.txt"
    wildcard_constraints:
        sample="Mock.*"
    group:
        "bam_process"
    conda: "conda_envs/star_env.yaml"
    #resources: cpus=1, mem_mb=4000
    shell:
        """
        mapped_host=$(samtools view -c -F 1284 {input.bam})
        uniquely_host=$(samtools view -c -F 1284 -q 255 {input.bam})
        total=`awk '{{if($0 ~ "Number of input reads"){{ split($0, x, "|"); gsub("\t","",x[2]); print x[2]}}}}' mapping/combined/{wildcards.sample}Log.final.out`
        echo $'sample\ttotal_reads\tmapped\tuniquely_mapped\tmapped_to_both\tgroup' > {output.stat}
        echo {wildcards.sample}'\t'${{total}}'\t'${{mapped_host}}'\t'${{uniquely_host}}'\t0\thost' >> {output.stat}
        cp {input.bam} {output.bam}
        """

rule split_bam_virus:
    input:
        bam="mapping/combined/{sample}.bam",
        idx="mapping/combined/{sample}.bam.bai"
    output:
        bam="mapping/combined/virus/{sample}.bam",
        bai="mapping/combined/virus/{sample}.bam.bai",
        sam=temp("mapping/combined/virus/{sample}.sam")
    params:
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome_annotation']
    wildcard_constraints:
        sample="(?!Mock).*"
    group:
        "bam_process"
    conda: "conda_envs/star_env.yaml"
    #resources: cpus=1, mem_mb=4000
    shell:
        """
        id=`cut -sf 1 {params.genome} | uniq`
        samtools view -H {input.bam} | awk -v id="${{id}}" '{{if ($0 ~ /@SQ/){{ split($2,b,":"); if(id ~ b[2]){{print $0}}}}else{{print $0}}}}' > {output.sam}
        samtools view {input.bam} $id >> {output.sam}
        samtools view -hb {output.sam} > {output.bam}
        samtools index {output.bam}
        """

rule split_bam_host:
    input:
        bam="mapping/combined/{sample}.bam",
        idx="mapping/combined/{sample}.bam.bai"
    output:
        "mapping/combined/host/{sample}.bam",
        #temp("mapping/combined/host/{sample}.sam")
    params:
        genome=lambda wildcards: config['entries'][wildcards.sample]['combined']['virus_genome_annotation']
    wildcard_constraints:
        sample="(?!Mock).*"
    group:
        "bam_process"
    conda: "conda_envs/star_env.yaml"
    #resources: cpus=1, mem_mb=4000
    shell:
        """
        id=`cut -sf 1 {params.genome} | uniq`
        id=`echo $id | sed -e 's/ /\\\\\\|/g'`
        samtools idxstats {input.bam} | cut -f 1 | grep -v $id | xargs samtools view -b {input.bam} > {output}
        """

