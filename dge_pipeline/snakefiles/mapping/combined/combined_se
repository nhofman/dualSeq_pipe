rule star_index:
    input:
        genome="%%HOST_GENOME%%"
    output:
        directory("%%STAR_INDEX_DIR%%")
    group:
        "star_index"
    log:
        "mapping/host/logs/star_index.log"
    threads:
        8
    shell:
        "STAR --runThreadN {threads} --runMode genomeGenerate --genomeDir {output} --genomeFastaFiles {input.genome} --sjdbGTFfile %%HOST_GTF%% --sjdbOverhang %%STAR_SJ_OVERHANG%% --sjdbGTFtagExonParentTranscript %%STAR_PARENT_TAG%% 2>&1 |"
        "tee {log}"


rule star_mapping:
    input:
        index_dir="%%STAR_INDEX_DIR%%",
        reads=lambda wildcards: os.path.join('preprocessing', os.path.basename(config['entries'][wildcards.sample]['main']['reads']))
    output:
        bam="mapping/host/{sample}.bam",
        summary="mapping/host/{sample}Log.final.out",
        fasta="mapping/host/{sample}Unmapped.out.mate1"
    group:
        "star_mapping"
    params:
        prefix="mapping/host/{sample}"
    log:
        "mapping/host/logs/star_mapping.{sample}.log"
    threads:
        2
    shell:
        #--outReadsUnmapped Fastx
        "STAR --runThreadN {threads} --runMode alignReads --genomeDir {input.index_dir} --readFilesIn {input.reads} --outSAMtype BAM SortedByCoordinate --outFileNamePrefix {params.prefix} --outReadsUnmapped Fastx %%ADDITIONAL_STAR_OPTIONS%% 2>&1 |"
        "tee {log}; mv {params.prefix}Aligned.sortedByCoord.out.bam {params.prefix}.bam"


rule star_unmapped_to_fastq:
    input:
        "mapping/host/{sample}Unmapped.out.mate1"
    output:
        "mapping/host/unmapped/{sample}.fastq"
    group:
        "star_mapping"
    shell:
        "mv {input} {output}"


# Calculate Index for each genome
rule bowtie2_index:
    input:
        "{genome_name}"
    output:
        "{genome_name}.1.bt2"
    group:
        "bowtie2_index"
    log:
        #"mapping/virus/logs/bowtie2_index.log"
        "{genome_name}.bowtie2.log"
    threads:
        8
    shell:
        "bowtie2-build --threads {threads} {input} {input} 2>&1 |"
        "tee -a {log}"


# map unmapped fastq files against corresponding reference (except Mock files!!)
rule bowtie2_mapping:
    input:
        reads="mapping/host/unmapped/{name}.fastq",
        genome=lambda wildcards: config['entries'][wildcards.name]['combined']['virus_genome'] + ".1.bt2"
    output:
        sam=temp("mapping/virus/sam/{name}.sam"),
        unmapped="mapping/virus/unmapped/{name}_unmapped.fastq",
        #log="mapping/virus/logs/bowtie2_mapping.{name}.log"
    group:
        "bowtie2_mapping"
    params:
       genome_base=lambda wildcards: config['entries'][wildcards.name]['combined']['virus_genome']
    log:
       "mapping/virus/logs/bowtie2_mapping.{name}.log"
    threads:
        2
    shell:
        "bowtie2 %%ADDITIONAL_BOWTIE2_OPTIONS%% -p {threads} --mm %%BOWTIE2_ALIGNMENT_TYPE%% -x {params.genome_base} -U {input.reads} -S {output.sam} --un {output.unmapped} 2>&1 |"
        "tee {log}"
        
def getGenome(wildcards):
    for entry in config['entries'].keys():
        if "Mock" not in entry:
            if wildcards.virus in entry:
                return config['entries'][entry]['combined']['virus_genome']+".1.bt2"
        
rule ctrl_mapping:
    input:
        index = getGenome,
        reads="mapping/host/unmapped/{ctrl}.fastq"
    output:
        sam=temp("mapping/virus/ctrl/{ctrl}_{virus}.sam")
    params:
        genome = lambda wildcards, input: input[0][:-6]
    log:
       "mapping/virus/ctrl/bowtie2_mapping.{ctrl}_{virus}.log"
    threads:
        4
    shell:
        "bowtie2 %%ADDITIONAL_BOWTIE2_OPTIONS%% -p {threads} --mm %%BOWTIE2_ALIGNMENT_TYPE%% -x {params.genome} -U {input.reads} -S {output.sam} 2>&1 | tee {log}"

        
rule star_index_bam:
    input:
        "mapping/host/{sample}.bam"
    output:
        "mapping/host/{sample}.bam.bai"
    threads:
        2
    shell:
        #"samtools sort -@ {threads} -o {output} {input} && samtools index {output}"
        "samtools index -@ {threads} {input}"
    

rule bowtie2_sam_to_bam:
    input:
        "mapping/virus/sam/{name}.sam",
    output:
        bam="mapping/virus/{name}.bam",
        bai="mapping/virus/{name}.bam.bai",
        bam_unmapped="mapping/virus/unmapped/{name}_unmap.bam"
    group:
        "bowtie2_mapping"
    wildcard_constraints:
        name="[^\\/]+"
    threads:
        2
    shell:
        "samtools view -F 4 -Shb {input} | samtools sort -@ {threads} -o {output.bam} - && samtools index {output.bam};"
        "samtools view -f 4 -Shb {input} | samtools sort -@ {threads} -o {output.bam_unmapped} -"
        
rule ctrl_sam_to_bam:
    input:
        "mapping/virus/ctrl/{ctrl}_{virus}.sam"
    output:
        bam="mapping/virus/ctrl/{ctrl}_{virus}.bam"
    group:
        "bowtie2_mapping"
    threads:
        2
    shell:
        "samtools view -F 4 -Shb {input} | samtools sort -@ {threads} -o {output.bam} - && samtools index {output.bam}"
