rule star_mapping_stats_tsv:
    input:
        expand("mapping/host/{sample}Log.final.out", sample=config['entries'].keys())
    output:
        "mapping/host/stats/mapping_stats.tsv"
    group:
        "star_statistics"
    run:
        with open(output[0], 'w') as summary_file:
            summary_file.write("sample	total_reads	avg_input_read_length	uniquely_mapped	uniquely_mapped_percent	avg_mapped_read_length	num_splices	num_annotated_splices	num_GT/AG_splices	num_GC/AG_splices	num_AT/AC_splices	num_noncanonical_splices	mismatch_rate	deletion_rate	deletion_length	insertion_rate	insertion_length	multimapped	multimapped_percent	multimapped_toomany	multimapped_toomany_percent	unmapped_mismatches	unmapped_mismatches_percent	unmapped_tooshort	unmapped_tooshort_percent	unmapped_other	unmapped_other_percent	chimeric	chimeric_percent\n")
            #pattern = {}
            for i in input:
                summary_file.write(i.replace("Log.final.out", "").replace("mapping/host/", ""))
                #with open(i, "r") as input_file:
                for line in shell("tail -n +5 {i}", iterable=True):
                        if "|" in line:
                            line_data = line.split("|")
                            summary_file.write("	" + line_data[1].split()[0])
                summary_file.write("\n")



rule bowtie2_mapping_stats_tsv:
    input:
        expand("mapping/virus/logs/bowtie2_mapping.{name}.log", name=sorted([entry for entry in config['entries'].keys() if "Mock" not in entry])),
        #expand("mapping/virus/ctrl/bowtie2_mapping.{ctrl}_{virus}.log", ctrl=[entry for entry in config['entries'].keys() if "Mock" in entry], virus=list(set([entry.split("_")[0] for entry in config['entries'].keys() if "Mock" not in entry])))
    output:
        "mapping/virus/stats/mapping_stats.tsv"
    group:
        "bowtie2_statistics"
    shell:
        """
        echo "sample	reads	reads[%]	aligned_0_times	aligned_0_times[%]	aligned_1_time	aligned_1_time[%]	aligned_more_than_1_times	aligned_more_than_1_times[%]	overall_alignment_rate" > {output}
        for i in {input}; do
            sample=$(basename $i);
            sample=${{sample%*.log}};
            sample=${{sample#bowtie2_mapping.}};
            echo -n $sample"	" >> {output};
            tail -n+2 $i | sed -e 's/^[^0-9]*\([0-9]\{{1,\}}\) (\([0-9.]\{{1,\}}\)%).*/\\1\t\\2/' | sed -e 's/^\(.*\)%.*$/\\1/' | tr '\n' '\t' | sed -e 's/\t$//' >> {output};
            echo >> {output};
        done;
        """

