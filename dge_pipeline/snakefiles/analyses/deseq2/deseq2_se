rule create_conditions_virus:  
    output:
        expand(temp("analyses/virus/deseq2/{virus}/{virus}_conditions.txt"), virus=list(set([entry.split('_')[0] for entry in config['entries'].keys() if "Mock" not in entry])))
    run:
        for o in output:
            with(open(o, 'w')) as output_file:
                for name in sorted([entry for entry in config['entries'].keys() if os.path.basename(o).split('_')[0] in entry]):
                    output_file.write('{}\t{}\n'.format(name, config['entries'][name]['deseq2']['condition']))
            
def getColor(virus):
    #list(set([entry.split('_')[0] for entry in config['entries'].keys() if "Mock" not in entry]))
    for entry in config['entries'].keys():
        if "Mock" not in entry:
            if entry.split('_')[0]==virus:
                return config['entries'][entry]['deseq2']['color']

