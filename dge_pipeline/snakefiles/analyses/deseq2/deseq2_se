rule count_reads_host:
    input:
        expand("mapping/host/{host}.bam", host=config['entries'].keys())
    output:
        counts = "analyses/host/deseq2/counts.txt",
        summary = "analyses/host/deseq2/counts.txt.summary"
    threads:
        8
    log:
        log="analyses/host/deseq2/logs/featurecounts.log"
    group:
        "count_reads"
    shell:
        "featureCounts -T {threads} %%ADDITIONAL_FEATCOUNTS_OPTIONS%% -t '%%GFF_FEATURE_TYPE_HUMAN%%' -g '%%GFF_FEATURE_NAME_HUMAN%%' -a %%GFF_HUMAN%% -o {output.counts} {input} 2>&1 |"
        "tee {log}"
        
def get_virus_bam(wildcards):
    bam = list()
    for entry in config['entries'].keys():
        if wildcards.virus in entry:
            bam.append("mapping/virus/"+entry+".bam")
            gff = config['entries'][entry]['combined']['virus_genome_annotation']
    bam.insert(0,gff)
    return bam            

